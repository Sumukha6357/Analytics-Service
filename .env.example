APP_ENV=local
SPRING_PROFILES_ACTIVE=local

API_PORT=9100
WEB_PORT=3000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=analytics
POSTGRES_USER=analytics
POSTGRES_PASSWORD=change-me

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2s

CACHE_TYPE=simple

ADMIN_API_KEY=change-me-admin-key
ANALYTICS_API_KEY=change-me-tenant-api-key
JWT_SECRET=change-me-jwt-secret
WEBHOOK_SECRET=change-me-webhook-secret

RETENTION_RAW_DAYS=30
RATE_LIMIT_EVENTS_PER_MIN=6000
MAX_BATCH_SIZE=100
MAX_EVENT_BYTES=65536
MAX_PROPERTIES_BYTES=49152
WORKER_CONCURRENCY=4
PARTITION_PRECREATE_DAYS=7
JOB_LOCK_TTL_SECONDS=120
JOB_BACKOFF_BASE_SECONDS=2
REVENUE_EVENT_NAME=OrderPlaced
ENABLE_GIN_PROPERTIES=false

NEXT_PUBLIC_API_BASE_URL=http://localhost:9100
NEXT_PUBLIC_ANALYTICS_ORGS=Primary Org
